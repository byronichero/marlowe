# Marlowe Copilot Runtime – Node bridge to FastAPI LangGraph agent
FROM node:20-alpine AS builder
WORKDIR /app
COPY copilot-runtime/package.json ./
RUN npm install --omit=dev

FROM node:20-alpine
WORKDIR /app
COPY --from=builder /app/node_modules ./node_modules
COPY copilot-runtime/ ./
EXPOSE 3010
ENV PORT=3010
CMD ["npm", "start"]
