{
  "uid": "marlowe-core-health",
  "title": "Marlowe Core Health",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "tags": ["marlowe", "core", "health"],
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "API (via Collector)",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 5 },
      "targets": [
        {
          "expr": "up{job=\"otel-collector\"}",
          "legendFormat": "otel-collector"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Postgres",
      "datasource": "Prometheus",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 5 },
      "targets": [
        {
          "expr": "up{job=\"postgres\"}",
          "legendFormat": "postgres"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Redis",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 5 },
      "targets": [
        {
          "expr": "up{job=\"redis\"}",
          "legendFormat": "redis"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Qdrant",
      "datasource": "Prometheus",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 5 },
      "targets": [
        {
          "expr": "up{job=\"qdrant\"}",
          "legendFormat": "qdrant"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Docker (cAdvisor)",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 5, "w": 6, "h": 5 },
      "targets": [
        {
          "expr": "up{job=\"cadvisor\"}",
          "legendFormat": "cadvisor"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Postgres Connections",
      "datasource": "Prometheus",
      "gridPos": { "x": 6, "y": 5, "w": 9, "h": 6 },
      "targets": [
        {
          "expr": "sum(pg_stat_database_numbackends)",
          "legendFormat": "connections"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Redis Memory Used",
      "datasource": "Prometheus",
      "gridPos": { "x": 15, "y": 5, "w": 9, "h": 6 },
      "targets": [
        {
          "expr": "redis_memory_used_bytes",
          "legendFormat": "bytes"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Container CPU (all services)",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 11, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_system_seconds_total[5m]))",
          "legendFormat": "cpu_system_seconds_total"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Container Memory (all services)",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 11, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{image!=\"\"})",
          "legendFormat": "memory_bytes"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "CPU by Service (backend/qdrant/postgres/redis)",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "sum by (container_label_com_docker_compose_service) (rate(container_cpu_system_seconds_total{container_label_com_docker_compose_service=~\"backend|qdrant|postgres|redis\"}[5m]))",
          "legendFormat": "{{container_label_com_docker_compose_service}}"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Memory by Service (backend/qdrant/postgres/redis)",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 18, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "sum by (container_label_com_docker_compose_service) (container_memory_working_set_bytes{image!=\"\",container_label_com_docker_compose_service=~\"backend|qdrant|postgres|redis\"})",
          "legendFormat": "{{container_label_com_docker_compose_service}}"
        }
      ]
    }
  ],
  "templating": { "list": [] }
}
