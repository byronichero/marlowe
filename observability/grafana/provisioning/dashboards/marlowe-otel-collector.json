{
  "uid": "marlowe-otel-collector",
  "title": "Marlowe Observability (Collector)",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "tags": ["marlowe", "otel", "collector"],
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Spans Received (OTLP)",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(otelcol_receiver_accepted_spans[5m]))",
          "legendFormat": "accepted"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Spans Exported (Tempo)",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(otelcol_exporter_sent_spans[5m]))",
          "legendFormat": "sent"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Collector Receive Queue Size",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "sum(otelcol_receiver_accepted_spans)",
          "legendFormat": "total"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Exporter Failed Spans",
      "datasource": "Prometheus",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(otelcol_exporter_send_failed_spans[5m]))",
          "legendFormat": "failed"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Tempo Ingested Spans",
      "datasource": "Prometheus",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(tempo_ingester_traces_created_total[5m]))",
          "legendFormat": "traces"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    }
  ],
  "templating": { "list": [] }
}
