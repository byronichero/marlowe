# Marlowe – copy to .env and set values

# App
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-in-production
DEBUG=false

# CORS (comma-separated or leave default)
# CORS_ORIGINS=http://localhost:8080,http://localhost:80

# PostgreSQL (backend in Docker uses postgres:5432; from host use localhost:5433)
DATABASE_URL=postgresql+asyncpg://marlowe:marlowe@postgres:5432/marlowe

# Redis
REDIS_URL=redis://redis:6379/0

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=marlowe_documents

# Neo4j
NEO4J_URI=neo4j://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Ollama (on host – use host.docker.internal for Docker backend)
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# MinIO / S3-compatible (on host or separate container)
MINIO_ENDPOINT=host.docker.internal:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=marlowe

# Optional credentials file path
# CREDENTIALS_FILE=/app/credentials.json

# Docs ingestion (path to folder; in Docker use "docs" with volume mount ./docs:/app/docs)
# DOCS_PATH=docs
# Embedding model for Qdrant (nomic-embed-text = 768 dimensions)
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_DIMENSION=768
