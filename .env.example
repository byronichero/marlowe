# Marlowe – copy to .env and set values

# App
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-in-production
DEBUG=false

# CORS (comma-separated or leave default)
# CORS_ORIGINS=http://localhost:8080,http://localhost:80

# PostgreSQL (backend in Docker uses postgres:5432; from host use localhost:5012)
DATABASE_URL=postgresql+asyncpg://marlowe:marlowe@postgres:5432/marlowe

# Redis
REDIS_URL=redis://redis:6379/0

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=marlowe_documents

# Neo4j
NEO4J_URI=neo4j://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Ollama (on host – use host.docker.internal for Docker backend; use http://localhost:11434 when backend runs on host)
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:latest
# If the chosen model returns 404 (not pulled), chat retries with this model.
OLLAMA_FALLBACK_MODEL=granite3.2:latest
OLLAMA_API_TIMEOUT=600

# LLM provider: ollama (default) or vllm
# LLM_PROVIDER=ollama

# vLLM (OpenAI-compatible)
# VLLM_BASE_URL=http://vllm:8000
# VLLM_API_KEY=
# VLLM_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
# VLLM_EMBEDDINGS_MODEL=
# VLLM_API_TIMEOUT=600

# MinIO / S3-compatible (on host or separate container)
MINIO_ENDPOINT=host.docker.internal:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=marlowe

# OpenTelemetry (local observability)
# OTEL_ENABLED=true
# OTEL_SERVICE_NAME=marlowe-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# OTEL_EXPORTER_OTLP_INSECURE=true

# Optional credentials file path
# CREDENTIALS_FILE=/app/credentials.json

# NIST auto-seed: load NIST 800-53 catalog on startup if not present (default: true)
# NIST_AUTO_SEED=true

# Docs ingestion (path to folder; in Docker use "docs" with volume mount ./docs:/app/docs)
# DOCS_PATH=docs
# Embedding model for Qdrant (nomic-embed-text = 768 dimensions)
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_DIMENSION=768

# Voice STT (faster-whisper): model size tiny|base|small|medium|large-v3, device cpu|cuda
# WHISPER_MODEL_SIZE=base
# WHISPER_DEVICE=cpu
